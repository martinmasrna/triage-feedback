# Copy to ".env" and fill in. Loaded automatically by src/server.ts; values set in the real
# environment override the file. A missing .env is fine — the server falls back to StubReader.

# Local LLM (llama.cpp, OpenAI-compatible). Omit/blank LLAMA_URL → StubReader (no extraction).
LLAMA_URL=http://127.0.0.1:8080
LLAMA_MODEL=<model-id-stamped-into-provenance>

# Prompt variant: "en" (English instructions, Slovak few-shot) or "sk" (Slovak instructions).
PROMPT_LANG=en

# HTTP port (default 8787) and SQLite file (default ./cases.db).
# PORT=8787
# DB_PATH=./cases.db

# Rule set YAML (default = the shipped provisional set).
# RULES_PATH=
